rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasAdminRole() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/roles/$(request.auth.uid))
        && get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role == "admin";
    }

    function isRoleDocOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidString(field, minLength, maxLength) {
      return field is string
        && field.size() >= minLength
        && field.size() <= maxLength;
    }

    function isValidOptionalString(field, maxLength) {
      return field is string && field.size() <= maxLength;
    }

    function isValidCounterPayload() {
      return request.resource.data.keys().hasOnly(["count", "updatedAt"])
        && request.resource.data.count is int
        && request.resource.data.count >= 0;
    }

    function isValidCounterCreate() {
      return isValidCounterPayload() && request.resource.data.count == 1;
    }

    function isValidCounterIncrement() {
      return isValidCounterPayload()
        && resource.data.count is int
        && request.resource.data.count == resource.data.count + 1;
    }

    function isValidContactCreate() {
      return request.resource.data.keys().hasOnly(["name", "email", "subject", "message", "source", "createdAt"])
        && request.resource.data.source == "portfolio"
        && isValidString(request.resource.data.name, 2, 120)
        && isValidString(request.resource.data.email, 5, 160)
        && isValidString(request.resource.data.subject, 2, 180)
        && isValidString(request.resource.data.message, 5, 5000);
    }

    function isValidSocialKind(value) {
      return value == "testimonial" || value == "feedback";
    }

    function isValidSocialCreate() {
      return request.resource.data.keys().hasOnly(["kind", "name", "role", "company", "message", "rating", "visible", "createdAt", "updatedAt"])
        && isValidSocialKind(request.resource.data.kind)
        && isValidString(request.resource.data.name, 2, 120)
        && isValidString(request.resource.data.role, 2, 120)
        && isValidOptionalString(request.resource.data.company, 120)
        && isValidString(request.resource.data.message, 10, 3000)
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.visible == true;
    }

    function isValidSocialUpdate() {
      return request.resource.data.keys().hasOnly(["kind", "name", "role", "company", "message", "rating", "visible", "createdAt", "updatedAt"])
        && isValidSocialKind(request.resource.data.kind)
        && isValidString(request.resource.data.name, 2, 120)
        && isValidString(request.resource.data.role, 2, 120)
        && isValidOptionalString(request.resource.data.company, 120)
        && isValidString(request.resource.data.message, 10, 3000)
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.visible is bool;
    }

    match /stats/visitorCount {
      allow read: if true;
      allow create: if isValidCounterCreate() || (hasAdminRole() && isValidCounterPayload());
      allow update: if isValidCounterIncrement() || (hasAdminRole() && isValidCounterPayload());
      allow delete: if false;
    }

    match /contactSubmissions/{documentId} {
      allow create: if isValidContactCreate();
      allow read: if hasAdminRole();
      allow update, delete: if false;
    }

    match /testimonials/{documentId} {
      allow create: if isValidSocialCreate();
      allow read: if hasAdminRole() || resource.data.visible == true;
      allow update: if hasAdminRole() && isValidSocialUpdate();
      allow delete: if hasAdminRole();
    }

    match /roles/{userId} {
      allow read: if hasAdminRole() || isRoleDocOwner(userId);
      allow write: if false;
    }
  }
}
